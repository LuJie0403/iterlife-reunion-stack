# IterLife deploy webhook environment example
# Copy to webhook/iterlife-deploy-webhook.env and fill real values
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_BIND_PORT=9000
WEBHOOK_PATH=/hooks/app-deploy
WEBHOOK_SECRET=CHANGE_ME
DEPLOY_TARGETS_JSON={"iterlife-reunion":"/apps/iterlife-reunion/deploy-reunion-from-ghcr.sh","iterlife-reunion-ui":"/apps/iterlife-reunion/deploy-reunion-ui-from-ghcr.sh","iterlife-expenses":"/apps/iterlife-expenses/deploy-expenses-api-from-ghcr.sh","iterlife-expenses-ui":"/apps/iterlife-expenses/deploy-expenses-ui-from-ghcr.sh"}
DEPLOY_TIMEOUT_SECONDS=600
WEBHOOK_LOG_FILE=/apps/logs/webhook/iterlife-deploy-webhook.log
GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=CHANGE_ME
GHCR_TOKEN=CHANGE_ME
